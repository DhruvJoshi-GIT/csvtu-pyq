---
import Base from '../../layouts/Base.astro';
import ResourceTabs from '../../components/ResourceTabs.astro';
import manifest from '../../data/manifest.json';
import { describeCourse } from '../../data/course-info';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const catalog = (manifest as any).catalog as any[];

// Only entries that have a downloaded scheme PDF
const schemeEntries = catalog.filter(e => e.schemeLocalPath);

// Group by program
const byProgram = new Map<string, any[]>();
for (const e of schemeEntries) {
  if (!byProgram.has(e.program)) byProgram.set(e.program, []);
  byProgram.get(e.program)!.push(e);
}
const cards = [...byProgram.entries()].map(([program, entries]) => {
  // Distinct sessions
  const sessions = new Set(entries.map(e => e.session).filter(Boolean));
  return {
    program,
    fullName: describeCourse(program),
    count: entries.length,
    sessions: [...sessions].sort().reverse(),
    href: `${baseUrl}/schemes/${encodeURIComponent(program)}/`,
  };
}).sort((a, b) => b.count - a.count);

const total = schemeEntries.length;
const crumbs = [
  { label: 'Home', href: `${baseUrl}/` },
  { label: 'Schemes' },
];
---
<Base title="Schemes — CSVTU PYQ" crumbs={crumbs}>
  <section class="container">
    <div class="hero" style="padding-top: var(--s-7); padding-bottom: var(--s-4);">
      <p class="eyebrow fade-in">Curriculum schemes</p>
      <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 56px);">Schemes</h1>
      <p class="hero__lede fade-in">
        {total} scheme PDFs across {cards.length} programs. Sourced from <a href="https://csvtu.ac.in/ew/programs-and-schemes/" target="_blank" rel="noopener" style="color: var(--accent-2);">csvtu.ac.in</a>. A scheme lists every subject, semester, and credit weighting for a course.
      </p>
      <ResourceTabs active="schemes" />
    </div>

    <div class="section" style="margin-top: var(--s-4);">
      <div class="section__head">
        <h2 class="section__title">Programs</h2>
        <span class="section__count">{cards.length} programs</span>
      </div>
      <div class="grid grid--lg">
        {cards.map((c, i) => (
          <a href={c.href} class="card fade-in" style={`animation-delay:${50 * (i % 9)}ms`}>
            <span class="card__chip">{c.count}</span>
            <h3 class="card__title">{c.program}</h3>
            {c.fullName && <p class="card__sub">{c.fullName}</p>}
            <p class="card__desc">
              {c.sessions.length > 0
                ? `Sessions: ${c.sessions.slice(0, 3).join(', ')}${c.sessions.length > 3 ? ` (+${c.sessions.length - 3})` : ''}`
                : 'Various sessions'}
            </p>
            <div class="card__stats"><span>{c.count} {c.count === 1 ? 'scheme' : 'schemes'}</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
