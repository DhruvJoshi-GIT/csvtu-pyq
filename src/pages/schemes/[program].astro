---
import Base from '../../layouts/Base.astro';
import ResourceTabs from '../../components/ResourceTabs.astro';
import manifest from '../../data/manifest.json';
import { describeCourse } from '../../data/course-info';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const m = (await import('../../data/manifest.json')).default as any;
  const catalog = m.catalog.filter((e: any) => e.schemeLocalPath);
  const byProgram = new Map<string, any[]>();
  for (const e of catalog) {
    if (!byProgram.has(e.program)) byProgram.set(e.program, []);
    byProgram.get(e.program)!.push(e);
  }
  return [...byProgram.entries()].map(([program, entries]) => ({
    params: { program: encodeURIComponent(program) },
    props: { program, entries },
  }));
}

const { program, entries } = Astro.props as any;
const fullName = describeCourse(program);

// Group by session, sorted newest first (Legacy at the bottom)
const bySession = new Map<string, any[]>();
for (const e of entries) {
  const s = e.session || 'Other';
  if (!bySession.has(s)) bySession.set(s, []);
  bySession.get(s)!.push(e);
}
function sessionOrder(s: string): number {
  if (s === 'Other') return 0;
  if (s === 'Legacy') return 1;
  const m = s.match(/^(\d{4})/);
  return m ? 100 + parseInt(m[1], 10) : 50;
}
const sessions = [...bySession.entries()]
  .sort((a, b) => sessionOrder(b[0]) - sessionOrder(a[0]))
  .map(([session, list]) => ({
    name: session,
    label: session === 'Legacy' ? 'Legacy / older curriculum' : (session === 'Other' ? 'Other / version unknown' : `Session ${session}`),
    entries: list.sort((a: any, b: any) => a.course.localeCompare(b.course)),
  }));

function formatDate(s: string | null): string {
  if (!s) return '—';
  const d = new Date(s);
  if (isNaN(d.valueOf())) return '—';
  return d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
}

const crumbs = [
  { label: 'Home', href: `${baseUrl}/` },
  { label: 'Schemes', href: `${baseUrl}/schemes/` },
  { label: program },
];
---
<Base title={`${program} Schemes — CSVTU PYQ`} crumbs={crumbs}>
  <section class="container">
    <div class="hero" style="padding-top: var(--s-7); padding-bottom: var(--s-4);">
      <p class="eyebrow fade-in">Schemes · {program}</p>
      <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 48px);">{program}</h1>
      {fullName && (
        <p class="fade-in" style="margin-top: var(--s-2); color: var(--text-1); font-size: 18px;">{fullName}</p>
      )}
      <p class="hero__lede fade-in">
        {entries.length} {entries.length === 1 ? 'scheme PDF' : 'scheme PDFs'} across {sessions.length} {sessions.length === 1 ? 'session' : 'sessions'}
      </p>
      <ResourceTabs active="schemes" />
    </div>

    <div class="section" style="margin-top: var(--s-4);">
      {sessions.map((session, i) => (
        <details class="topic fade-in" style={`animation-delay:${40 * (i % 9)}ms`} open={i === 0}>
          <summary class="topic__head">
            <span class="row" style="gap: var(--s-3); min-width: 0;">
              <svg class="topic__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              <span class="topic__name">{session.label}</span>
            </span>
            <span class="topic__meta">{session.entries.length} {session.entries.length === 1 ? 'scheme' : 'schemes'}</span>
          </summary>
          <div class="topic__body" style="display: flex; flex-direction: column; gap: var(--s-2);">
            {session.entries.map((e: any) => (
              <div class="paper">
                <div style="flex: 1; min-width: 0;">
                  <div class="paper__title" style="text-transform: none;">{e.course}</div>
                  <div class="paper__meta">
                    Last updated {formatDate(e.schemeLastModified)}
                    {e.schemeBytes && <> · {(e.schemeBytes / 1024).toFixed(0)} KB</>}
                  </div>
                </div>
                <a class="paper__btn" href={`${baseUrl}${e.schemeLocalPath}`} target="_blank" rel="noopener">View PDF</a>
              </div>
            ))}
          </div>
        </details>
      ))}
    </div>
  </section>
</Base>
