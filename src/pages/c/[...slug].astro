---
import Base from '../../layouts/Base.astro';
import manifest from '../../data/manifest.json';
import { describeCourse, describeBranch } from '../../data/course-info';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const m = (await import('../../data/manifest.json')).default as any;
  const paths: any[] = [];

  for (const course of m.tree) {
    paths.push({
      params: { slug: encodeURIComponent(course.name) },
      props: { view: 'course', course },
    });

    for (const branch of course.branches) {
      // _ branch: skip the branch view, promote sems to top-level under course
      if (branch.name === '_') {
        for (const sem of branch.sems) {
          paths.push({
            params: { slug: `${encodeURIComponent(course.name)}/${encodeURIComponent(sem.name)}` },
            props: { view: 'sem', course, branch, sem },
          });
          // Subject pages under this sem
          for (const subject of sem.subjects) {
            const segs = [encodeURIComponent(course.name), encodeURIComponent(sem.name)];
            if (subject.topic) segs.push(encodeURIComponent(subject.topic));
            segs.push(encodeURIComponent(subject.name));
            paths.push({
              params: { slug: segs.join('/') },
              props: { view: 'subject', course, branch, sem, subject },
            });
          }
        }
        continue;
      }

      // Real branch — branch view + sems + subjects
      paths.push({
        params: { slug: `${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}` },
        props: { view: 'branch', course, branch },
      });

      for (const sem of branch.sems) {
        paths.push({
          params: { slug: `${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}/${encodeURIComponent(sem.name)}` },
          props: { view: 'sem', course, branch, sem },
        });
        for (const subject of sem.subjects) {
          const segs = [encodeURIComponent(course.name), encodeURIComponent(branch.name), encodeURIComponent(sem.name)];
          if (subject.topic) segs.push(encodeURIComponent(subject.topic));
          segs.push(encodeURIComponent(subject.name));
          paths.push({
            params: { slug: segs.join('/') },
            props: { view: 'subject', course, branch, sem, subject },
          });
        }
      }
    }
  }

  return paths;
}

const props = Astro.props as any;
const view = props.view as 'course' | 'branch' | 'sem' | 'subject';
const course = props.course;
const branch = props.branch;
const sem = props.sem;
const subject = props.subject;

// ============ Helpers ============
function paperCount(branch: any): number {
  let n = 0;
  for (const s of branch.sems) for (const sub of s.subjects) n += sub.count;
  return n;
}
function semPaperCount(sem: any): number {
  let n = 0;
  for (const sub of sem.subjects) n += sub.count;
  return n;
}
function semLabel(name: string): string {
  return name.replace('Sem-', 'Semester ').replace('1st-Year', '1st Year').replace('Unknown-Sem', 'Other');
}
function isSingleBranch(c: any): boolean {
  return c.branches.length === 1 && c.branches[0].name === '_';
}
function prettyName(name: string): string {
  return name.replace(/-/g, ' ');
}
function subjectHref(course: any, branch: any, sem: any, subject: any): string {
  const segs = [encodeURIComponent(course.name)];
  if (branch.name !== '_') segs.push(encodeURIComponent(branch.name));
  segs.push(encodeURIComponent(sem.name));
  if (subject.topic) segs.push(encodeURIComponent(subject.topic));
  segs.push(encodeURIComponent(subject.name));
  return `${baseUrl}/c/${segs.join('/')}/`;
}

// Renders the small BE/BTech/Mixed chip; null when no era is known.
function eraChip(era: string | undefined): { label: string; cls: string } | null {
  if (era === 'BE') return { label: 'BE legacy', cls: 'era era--be' };
  if (era === 'BTech') return { label: 'BTech', cls: 'era era--btech' };
  if (era === 'mixed') return { label: 'BE + BTech', cls: 'era era--mixed' };
  return null;
}

// ============ Course view data ============
type CourseCard = { name: string; sub: string | undefined; desc: string; papers: number; href: string };
let courseCards: CourseCard[] = [];
let courseTotalPapers = 0;
let courseHeading = 'Branches';
let courseSubtitle: string | undefined = undefined;

if (view === 'course') {
  for (const b of course.branches) courseTotalPapers += paperCount(b);
  courseSubtitle = describeCourse(course.name);

  if (isSingleBranch(course)) {
    courseHeading = 'Semesters';
    courseCards = course.branches[0].sems.map((s: any) => ({
      name: semLabel(s.name),
      sub: undefined,
      desc: `${s.subjects.length} subject${s.subjects.length === 1 ? '' : 's'}`,
      papers: semPaperCount(s),
      href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(s.name)}/`,
    }));
  } else {
    const realBranches = course.branches.filter((b: any) => b.name !== '_');
    const underscore = course.branches.find((b: any) => b.name === '_');
    courseHeading = underscore ? 'Branches & shared papers' : 'Branches';

    if (underscore) {
      for (const s of underscore.sems) {
        courseCards.push({
          name: semLabel(s.name),
          sub: 'Shared across all branches',
          desc: `${s.subjects.length} subject${s.subjects.length === 1 ? '' : 's'}`,
          papers: semPaperCount(s),
          href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(s.name)}/`,
        });
      }
    }
    for (const b of realBranches) {
      courseCards.push({
        name: b.name,
        sub: describeBranch(b.name),
        desc: `${b.sems.length} semester${b.sems.length === 1 ? '' : 's'}`,
        papers: paperCount(b),
        href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(b.name)}/`,
      });
    }
  }
}

// ============ Branch view data ============
let branchSemCards: any[] = [];
let branchTotalPapers = 0;
let branchSubtitle: string | undefined = undefined;
if (view === 'branch') {
  branchTotalPapers = paperCount(branch);
  branchSubtitle = describeBranch(branch.name);
  branchSemCards = branch.sems.map((s: any) => ({
    name: s.name,
    label: semLabel(s.name),
    papers: semPaperCount(s),
    subjects: s.subjects.length,
    href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}/${encodeURIComponent(s.name)}/`,
  }));
}

// ============ Sem view data ============
type TopicGroup = { name: string; subjects: any[]; subjectCount: number; paperCount: number };
let semTopics: TopicGroup[] = [];
let semUngrouped: any[] = [];
let semTotalPapers = 0;

if (view === 'sem') {
  const byTopic = new Map<string, any[]>();
  for (const s of sem.subjects) {
    if (s.topic) {
      if (!byTopic.has(s.topic)) byTopic.set(s.topic, []);
      byTopic.get(s.topic)!.push(s);
    } else {
      semUngrouped.push(s);
    }
    semTotalPapers += s.count;
  }
  semTopics = [...byTopic.entries()]
    .sort((a, b) => a[0].localeCompare(b[0]))
    .map(([topicName, subjects]) => ({
      name: topicName,
      subjects: subjects.sort((a: any, b: any) => a.name.localeCompare(b.name)),
      subjectCount: subjects.length,
      paperCount: subjects.reduce((a: number, s: any) => a + s.count, 0),
    }));
}

// ============ Subject view data ============
let subjectPapers: any[] = [];
let subjectByYear: Array<{ year: string; papers: any[] }> = [];

if (view === 'subject') {
  const allPapers = (manifest as any).papers as any[];
  // Aliased subjects pull papers from the canonical (source) location.
  const paperCourse = subject.aliasOf?.course ?? course.name;
  const paperBranch = subject.aliasOf?.branch ?? branch.name;
  const paperSem = subject.aliasOf?.sem ?? sem.name;
  const paperTopic = subject.aliasOf?.topic !== undefined ? subject.aliasOf.topic : subject.topic;
  subjectPapers = allPapers.filter(p =>
    p.course === paperCourse &&
    p.branch === paperBranch &&
    p.sem === paperSem &&
    p.subject === subject.name &&
    (paperTopic ? p.topic === paperTopic : !p.topic)
  );

  const byYearMap = new Map<string, any[]>();
  for (const p of subjectPapers) {
    if (!byYearMap.has(p.year)) byYearMap.set(p.year, []);
    byYearMap.get(p.year)!.push(p);
  }
  subjectByYear = [...byYearMap.entries()]
    .sort((a, b) => b[0].localeCompare(a[0]))
    .map(([year, papers]) => ({ year, papers }));
}

// ============ Crumbs + title ============
let crumbs: Array<{ label: string; href?: string }> = [{ label: 'Home', href: `${baseUrl}/` }];
let title = '';

if (view === 'course') {
  crumbs.push({ label: course.name });
  title = `${course.name} — CSVTU PYQ`;
} else if (view === 'branch') {
  crumbs.push({ label: course.name, href: `${baseUrl}/c/${encodeURIComponent(course.name)}/` });
  crumbs.push({ label: branch.name });
  title = `${course.name} ${branch.name} — CSVTU PYQ`;
} else if (view === 'sem') {
  crumbs.push({ label: course.name, href: `${baseUrl}/c/${encodeURIComponent(course.name)}/` });
  if (branch.name !== '_') {
    crumbs.push({ label: branch.name, href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}/` });
  }
  crumbs.push({ label: semLabel(sem.name) });
  title = `${course.name}${branch.name === '_' ? '' : ' ' + branch.name} ${semLabel(sem.name)} — CSVTU PYQ`;
} else {
  // subject
  crumbs.push({ label: course.name, href: `${baseUrl}/c/${encodeURIComponent(course.name)}/` });
  if (branch.name !== '_') {
    crumbs.push({ label: branch.name, href: `${baseUrl}/c/${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}/` });
  }
  const semSegs = branch.name !== '_'
    ? `${encodeURIComponent(course.name)}/${encodeURIComponent(branch.name)}/${encodeURIComponent(sem.name)}`
    : `${encodeURIComponent(course.name)}/${encodeURIComponent(sem.name)}`;
  crumbs.push({ label: semLabel(sem.name), href: `${baseUrl}/c/${semSegs}/` });
  if (subject.topic) {
    crumbs.push({ label: subject.topic.replace(/-/g, ' ') });
  }
  crumbs.push({ label: prettyName(subject.name) });
  title = `${prettyName(subject.name)} — ${course.name}${branch.name === '_' ? '' : ' ' + branch.name} ${semLabel(sem.name)} · CSVTU PYQ`;
}
---
<Base title={title} crumbs={crumbs}>
  {view === 'course' && (
    <section class="container">
      <div class="hero" style="padding-top: var(--s-7); padding-bottom: var(--s-5);">
        <p class="eyebrow fade-in">Course</p>
        <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 56px);">{course.name}</h1>
        {courseSubtitle && (
          <p class="fade-in" style="margin-top: var(--s-2); color: var(--text-1); font-size: 18px;">{courseSubtitle}</p>
        )}
        <p class="hero__lede fade-in">
          {courseCards.length} {courseHeading.toLowerCase()} · {courseTotalPapers.toLocaleString()} papers
        </p>
      </div>

      <div class="section">
        <div class="section__head">
          <h2 class="section__title">{courseHeading}</h2>
        </div>
        <div class="grid">
          {courseCards.map((c, i) => (
            <a href={c.href} class="card fade-in" style={`animation-delay:${50 * (i % 9)}ms`}>
              <span class="card__chip">{c.papers}</span>
              <h3 class="card__title">{c.name}</h3>
              {c.sub && <p class="card__sub">{c.sub}</p>}
              <p class="card__desc">{c.desc}</p>
              <div class="card__stats"><span>{c.papers.toLocaleString()} papers</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {view === 'branch' && (
    <section class="container">
      <div class="hero" style="padding-top: var(--s-7); padding-bottom: var(--s-5);">
        <p class="eyebrow fade-in">{course.name}</p>
        <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 56px);">{branch.name}</h1>
        {branchSubtitle && (
          <p class="fade-in" style="margin-top: var(--s-2); color: var(--text-1); font-size: 18px;">{branchSubtitle}</p>
        )}
        <p class="hero__lede fade-in">
          {branchSemCards.length} semester{branchSemCards.length === 1 ? '' : 's'} · {branchTotalPapers.toLocaleString()} papers
        </p>
      </div>

      <div class="section">
        <div class="section__head">
          <h2 class="section__title">Semesters</h2>
        </div>
        <div class="grid">
          {branchSemCards.map((s, i) => (
            <a href={s.href} class="card fade-in" style={`animation-delay:${50 * (i % 9)}ms`}>
              <span class="card__chip">{s.papers}</span>
              <h3 class="card__title">{s.label}</h3>
              <p class="card__desc">{s.subjects} subject{s.subjects === 1 ? '' : 's'}</p>
              <div class="card__stats"><span>{s.papers.toLocaleString()} papers</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {view === 'sem' && (
    <section class="container">
      <div class="hero" style="padding-top: var(--s-7); padding-bottom: var(--s-5);">
        <p class="eyebrow fade-in">
          {course.name}{branch.name !== '_' ? ` · ${branch.name}` : ''}
        </p>
        <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 56px);">
          {semLabel(sem.name)}
        </h1>
        <p class="hero__lede fade-in">
          {sem.subjects.length} subject{sem.subjects.length === 1 ? '' : 's'} · {semTotalPapers.toLocaleString()} papers
        </p>
        <p class="muted fade-in" style="margin-top: var(--s-3); font-size: 14px;">
          Tap a subject to see its year-by-year papers.
        </p>
      </div>

      {semTopics.length > 0 && (
        <div class="section">
          <div class="section__head">
            <h2 class="section__title">Topics</h2>
            <span class="section__count">{semTopics.length} topics</span>
          </div>
          <div class="stack">
            {semTopics.map((topic, i) => (
              <details class="topic fade-in" style={`animation-delay:${40 * (i % 9)}ms`} open={i < 2}>
                <summary class="topic__head">
                  <span class="row" style="gap: var(--s-3); min-width: 0;">
                    <svg class="topic__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                    <span class="topic__name">{topic.name.replace(/-/g, ' ')}</span>
                  </span>
                  <span class="topic__meta">
                    {topic.subjectCount} subject{topic.subjectCount === 1 ? '' : 's'} · {topic.paperCount} papers
                  </span>
                </summary>
                <div class="topic__body">
                  {topic.subjects.map((s: any) => {
                    const chip = eraChip(s.era);
                    return (
                      <a href={subjectHref(course, branch, sem, s)} class="subject">
                        <span class="subject__name">
                          {s.name.replace(/-/g, ' ')}
                          {chip && <span class={chip.cls}>{chip.label}</span>}
                        </span>
                        <span class="subject__count">{s.count} paper{s.count === 1 ? '' : 's'} · {s.years.length} year{s.years.length === 1 ? '' : 's'}</span>
                      </a>
                    );
                  })}
                </div>
              </details>
            ))}
          </div>
        </div>
      )}

      {semUngrouped.length > 0 && (
        <div class="section">
          <div class="section__head">
            <h2 class="section__title">Other subjects</h2>
            <span class="section__count">{semUngrouped.length} subjects</span>
          </div>
          <div class="grid">
            {semUngrouped.map((s, i) => {
              const chip = eraChip(s.era);
              return (
                <a href={subjectHref(course, branch, sem, s)} class="card fade-in" style={`animation-delay:${30 * (i % 9)}ms`}>
                  <span class="card__chip">{s.count}</span>
                  <h3 class="card__title">{s.name.replace(/-/g, ' ')}</h3>
                  <p class="card__desc">
                    {s.years.length} year{s.years.length === 1 ? '' : 's'}
                    {chip && <span class={chip.cls} style="margin-left:8px;">{chip.label}</span>}
                  </p>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </section>
  )}

  {view === 'subject' && (
    <section class="container">
      <div class="hero" style="padding-top: var(--s-6); padding-bottom: var(--s-4);">
        <p class="eyebrow fade-in">
          {course.name}{branch.name !== '_' ? ` · ${branch.name}` : ''} · {semLabel(sem.name)}
          {subject.topic && (
            <> · {subject.topic.replace(/-/g, ' ')}</>
          )}
        </p>
        <h1 class="fade-in" style="margin-top: var(--s-2); font-size: clamp(28px, 5vw, 48px); text-transform: capitalize;">
          {prettyName(subject.name)}
        </h1>
        <p class="hero__lede fade-in">
          {subjectPapers.length} paper{subjectPapers.length === 1 ? '' : 's'} · {subjectByYear.length} year{subjectByYear.length === 1 ? '' : 's'}
        </p>
        {subject.era === 'BE' && (
          <p class="era-banner era-banner--be fade-in">
            <strong>Legacy BE scheme.</strong> All papers here are from CSVTU's pre-2020 BE (Bachelor of Engineering) curriculum. The current BTech scheme uses different subject codes and may not include this subject in the same semester.
          </p>
        )}
        {subject.era === 'mixed' && (
          <p class="era-banner era-banner--mixed fade-in">
            <strong>Mixed scheme.</strong> Includes papers from both the older BE curriculum and the current BTech curriculum. Each paper below is tagged with its scheme.
          </p>
        )}
        <p class="muted fade-in" style="margin-top: var(--s-3); font-size: 14px;">
          Tap a year to expand its papers.
        </p>
      </div>

      <div class="section" style="margin-top: var(--s-4);">
        <div class="stack-tight">
          {subjectByYear.map((yearGroup, i) => (
            <details class="year-acc fade-in" style={`animation-delay:${40 * (i % 9)}ms`} open={i === 0} id={`year-${yearGroup.year}`}>
              <summary class="year-acc__head">
                <span class="row" style="gap: var(--s-3); min-width: 0;">
                  <svg class="year-acc__caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                  <span class="year-acc__num">{yearGroup.year === 'unknown-year' ? '—' : yearGroup.year}</span>
                </span>
                <span class="year-acc__count">{yearGroup.papers.length} paper{yearGroup.papers.length === 1 ? '' : 's'}</span>
              </summary>
              <div class="year-acc__body">
                {yearGroup.papers.map((p: any) => {
                  const monthMatch = p.filename.match(/-(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)-/i);
                  const month = monthMatch ? monthMatch[1].toUpperCase() : '';
                  const sizeKB = (p.bytes / 1024).toFixed(0);
                  const label = month ? `${month} ${yearGroup.year}` : prettyName(p.filename.replace(/\.pdf$/, ''));
                  const paperChip = p.degree === 'BE' ? { label: 'BE', cls: 'era era--be era--paper' }
                    : p.degree === 'BTech' ? { label: 'BTech', cls: 'era era--btech era--paper' }
                    : null;
                  return (
                    <div class="paper">
                      <div style="flex: 1; min-width: 0;">
                        <div class="paper__title">
                          {label}
                          {paperChip && <span class={paperChip.cls}>{paperChip.label}</span>}
                        </div>
                        <div class="paper__meta">{sizeKB} KB · {p.filename}</div>
                      </div>
                      <a class="paper__btn" href={`${baseUrl}${p.path}`} target="_blank" rel="noopener">View PDF</a>
                    </div>
                  );
                })}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
