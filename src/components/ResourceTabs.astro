---
// Tab navigation shared between /schemes and /syllabus pages.
interface Props {
  active: 'schemes' | 'syllabus';
}
const { active } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<nav class="restabs">
  <a href={`${baseUrl}/schemes/`} class={`restabs__tab ${active === 'schemes' ? 'restabs__tab--active' : ''}`}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
    </svg>
    Schemes
  </a>
  <a href={`${baseUrl}/syllabus/`} class={`restabs__tab ${active === 'syllabus' ? 'restabs__tab--active' : ''}`}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
    </svg>
    Syllabus
  </a>
</nav>
